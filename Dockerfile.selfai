# syntax=docker/dockerfile:1.5
#
# Self.AI Curator: NeMo Curator + FastAPI control API
# Extends the upstream NeMo Curator Docker image with a FastAPI wrapper
# for job-based pipeline execution.
#

# ─── Stage 1: Build NeMo Curator (reuse upstream Dockerfile stages) ──────────
ARG CUDA_VER=12.8.1
ARG LINUX_VER=ubuntu24.04

FROM nvidia/cuda:${CUDA_VER}-cudnn-devel-${LINUX_VER} AS cuda

FROM cuda AS build

ARG CURATOR_ENV=ci
ENV CURATOR_ENVIRONMENT=${CURATOR_ENV}
ENV NVIDIA_PRODUCT_NAME="NeMo Curator"
ENV PIP_BREAK_SYSTEM_PACKAGES=1
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.12-dev \
    python3 \
    python3-dev \
    python3-venv \
    python-is-python3 \
    curl \
    git \
    vim && \
    apt-get install -y --only-upgrade gnupg && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /opt

# Install uv
ENV UV_VERSION="0.8.22"
RUN curl -LsSf https://astral.sh/uv/${UV_VERSION}/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"
ENV UV_PROJECT_ENVIRONMENT=/opt/venv
ENV UV_CACHE_DIR=/opt/uv_cache
ENV PATH="$UV_PROJECT_ENVIRONMENT/bin:$PATH"
ENV UV_LINK_MODE=copy
RUN uv venv ${UV_PROJECT_ENVIRONMENT} --system-site-packages

# Install NeMo Curator with text_cpu extra only (no vLLM, no RAPIDS).
# GPU-accelerated dedup and classifiers can be added later via text_cuda12.
WORKDIR /opt/Curator
COPY pyproject.toml uv.lock /opt/Curator/
COPY nemo_curator/__init__.py nemo_curator/package_info.py /opt/Curator/nemo_curator/

RUN uv sync --link-mode copy --locked --extra text_cpu --all-groups --no-cache && \
    find /opt/venv -type d -path "*ray/_private/runtime_env/agent/thirdparty_files/aiohttp*" -exec rm -rf {} +

COPY . /opt/Curator

# ─── Stage 2: Runtime image with FastAPI API layer ───────────────────────────
FROM nvidia/cuda:${CUDA_VER}-cudnn-devel-${LINUX_VER} AS runtime

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3.12 python3.12-dev python3-venv python-is-python3 \
        curl supervisor vim && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Create supervisor log directory
RUN mkdir -p /var/log/supervisor

# Copy the built venv from the build stage
COPY --from=build /opt/venv /opt/venv
COPY --from=build /opt/Curator /opt/Curator

ENV PATH="/opt/venv/bin:${PATH}"
ENV UV_PROJECT_ENVIRONMENT=/opt/venv
ENV UV_LINK_MODE=copy
ENV PYTHONUNBUFFERED=1
ENV HF_HOME="/workspace/curator/cache/hf-hub"

# Install uv in runtime for adding packages
RUN curl -LsSf https://astral.sh/uv/0.8.22/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# Install FastAPI and dependencies into the existing venv
RUN uv pip install --no-cache-dir \
    fastapi "uvicorn[standard]" aiofiles pyyaml

# Create workspace directories
RUN mkdir -p /workspace/curator/data \
             /workspace/curator/configs \
             /workspace/curator/logs \
             /workspace/curator/jobs \
             /workspace/curator/cache/hf-hub \
             /workspace/curator/custom_stages

# Copy API code
COPY api/ /app/api/

# supervisord configuration
COPY supervisord.conf /etc/supervisor/conf.d/curator.conf

# Entrypoint script
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 8094

WORKDIR /workspace/curator

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8094/health || exit 1

ENTRYPOINT ["/entrypoint.sh"]
